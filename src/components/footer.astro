---
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="frame foot-row">
    <span>© {year} · Steven Jhonson Haposan Siahaan</span>
  </div>
</footer>

<style>
  footer.foot {
    padding: 32px 0;
    border-top: 1px solid var(--rule);
  }
  .foot-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
  }
</style>
